<?xml version="1.0" encoding="utf-8"?>
<!--
  アダプティブアイコン background。
  iOS アイコンのグラデ（左上マゼンタ → 右下ディープレッド、右上に黄みのアクセント）を
  shape + gradient で再現。ハーフトーンは省略し、低解像度での視認性を優先。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="#D7148B"
        android:centerColor="#E23658"
        android:endColor="#EB143F" />
</shape>
