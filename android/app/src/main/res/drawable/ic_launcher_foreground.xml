<?xml version="1.0" encoding="utf-8"?>
<!--
  アダプティブアイコン foreground。
  iOS アイコンの D-pad + 4 ボタンデザインを vector 化し、低解像度でも鮮明に見えるように
  outline ではなく filled で描く。108dp canvas の中央 safe zone (66dp) に収めてある。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- D-pad (left, 十字): 水平バー + 垂直バーの重ね合わせ -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 25 48 L 51 48 Q 53 48 53 50 L 53 58 Q 53 60 51 60 L 25 60 Q 23 60 23 58 L 23 50 Q 23 48 25 48 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 36 37 L 40 37 Q 42 37 42 39 L 42 69 Q 42 71 40 71 L 36 71 Q 34 71 34 69 L 34 39 Q 34 37 36 37 Z" />

    <!-- 4 buttons (right, 菱形配置): 上/右/下/左 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 72 44 m -5 0 a 5 5 0 1 0 10 0 a 5 5 0 1 0 -10 0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 82 54 m -5 0 a 5 5 0 1 0 10 0 a 5 5 0 1 0 -10 0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 72 64 m -5 0 a 5 5 0 1 0 10 0 a 5 5 0 1 0 -10 0 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 62 54 m -5 0 a 5 5 0 1 0 10 0 a 5 5 0 1 0 -10 0 Z" />
</vector>
